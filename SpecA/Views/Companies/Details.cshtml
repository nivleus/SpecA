@model SpecA.Models.Company
@{
    ViewData["Title"] = Model.Name;
}

<div class="pagetitle">
    <h1>@Model.Name</h1>
    <nav>
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Dashboard</a></li>
            <li class="breadcrumb-item"><a asp-action="Index">Companies</a></li>
            <li class="breadcrumb-item active">@Model.Name</li>
        </ol>
    </nav>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<section class="section">
    <div class="row">
        <div class="col-lg-5">
            <div class="card">
                <div class="card-body pt-4">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h5 class="card-title m-0">Company Details</h5>
                        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-sm btn-outline-primary"><i class="bi bi-pencil"></i> Edit</a>
                    </div>
                    <dl class="row mb-0">
                        <dt class="col-sm-4">Name</dt><dd class="col-sm-8">@Model.Name</dd>
                        <dt class="col-sm-4">Code</dt><dd class="col-sm-8">@(string.IsNullOrWhiteSpace(Model.Code) ? "—" : Model.Code)</dd>
                        <dt class="col-sm-4">Industry</dt><dd class="col-sm-8">@(string.IsNullOrWhiteSpace(Model.Industry) ? "—" : Model.Industry)</dd>
                        <dt class="col-sm-4">Address</dt><dd class="col-sm-8">@(string.IsNullOrWhiteSpace(Model.Address) ? "—" : Model.Address)</dd>
                        <dt class="col-sm-4">Email</dt><dd class="col-sm-8">@(string.IsNullOrWhiteSpace(Model.ContactEmail) ? "—" : Model.ContactEmail)</dd>
                        <dt class="col-sm-4">Phone</dt><dd class="col-sm-8">@(string.IsNullOrWhiteSpace(Model.ContactPhone) ? "—" : Model.ContactPhone)</dd>
                        <dt class="col-sm-4">Website</dt><dd class="col-sm-8">@(string.IsNullOrWhiteSpace(Model.Website) ? "—" : Model.Website)</dd>
                        <dt class="col-sm-4">Status</dt>
                        <dd class="col-sm-8">
                            @if (Model.IsActive)
                            {
                                <span class="badge bg-success">Active</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Inactive</span>
                            }
                        </dd>
                    </dl>
                </div>
            </div>
        </div>

        <div class="col-lg-7">
            <div class="card">
                <div class="card-body pt-4">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h5 class="card-title m-0">Departments</h5>
                        <a asp-controller="Departments" asp-action="Create" asp-route-companyId="@Model.Id" class="btn btn-sm btn-primary">
                            <i class="bi bi-plus-lg"></i> Add Department
                        </a>
                    </div>

                    @if (!Model.Departments.Any())
                    {
                        <div class="text-center text-muted py-4">
                            <i class="bi bi-diagram-3 fs-1 d-block mb-2"></i>
                            No departments yet for this company.
                        </div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-hover align-middle">
                                <thead>
                                    <tr>
                                        <th>Name</th>
                                        <th>Code</th>
                                        <th>Manager</th>
                                        <th>Phone</th>
                                        <th>Status</th>
                                        <th class="text-end">Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var dept in Model.Departments)
                                    {
                                        <tr>
                                            <td class="fw-semibold">@dept.Name</td>
                                            <td>@(string.IsNullOrWhiteSpace(dept.Code) ? "—" : dept.Code)</td>
                                            <td>@(string.IsNullOrWhiteSpace(dept.Manager) ? "—" : dept.Manager)</td>
                                            <td>@(string.IsNullOrWhiteSpace(dept.Phone) ? "—" : dept.Phone)</td>
                                            <td>
                                                @if (dept.IsActive)
                                                {
                                                    <span class="badge bg-success">Active</span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-secondary">Inactive</span>
                                                }
                                            </td>
                                            <td class="text-end">
                                                <a asp-controller="Departments" asp-action="Edit" asp-route-id="@dept.Id" class="btn btn-sm btn-outline-primary"><i class="bi bi-pencil"></i></a>
                                                <a asp-controller="Departments" asp-action="Delete" asp-route-id="@dept.Id" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></a>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    <div class="mb-4">
        <a asp-action="Index" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Back to Companies</a>
    </div>
</section>
