@model IEnumerable<SpecA.Models.Company>
@{
    ViewData["Title"] = "Companies";
}

<div class="pagetitle">
    <h1>Companies</h1>
    <nav>
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Dashboard</a></li>
            <li class="breadcrumb-item active">Companies</li>
        </ol>
    </nav>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<section class="section">
    <div class="card">
        <div class="card-body">
            <div class="d-flex justify-content-between align-items-center pt-3 pb-2">
                <h5 class="card-title m-0">Company Register</h5>
                <a asp-action="Create" class="btn btn-primary btn-sm">
                    <i class="bi bi-plus-lg"></i> Add Company
                </a>
            </div>

            @if (!Model.Any())
            {
                <div class="text-center text-muted py-5">
                    <i class="bi bi-building fs-1 d-block mb-2"></i>
                    No companies yet. Click <strong>Add Company</strong> to create the first one.
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle">
                        <thead>
                            <tr>
                                <th>Name</th>
                                <th>Code</th>
                                <th>Industry</th>
                                <th>Departments</th>
                                <th>Status</th>
                                <th class="text-end">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var company in Model)
                            {
                                <tr>
                                    <td><a asp-action="Details" asp-route-id="@company.Id" class="fw-semibold">@company.Name</a></td>
                                    <td>@(string.IsNullOrWhiteSpace(company.Code) ? "—" : company.Code)</td>
                                    <td>@(string.IsNullOrWhiteSpace(company.Industry) ? "—" : company.Industry)</td>
                                    <td><span class="badge bg-info">@company.Departments.Count</span></td>
                                    <td>
                                        @if (company.IsActive)
                                        {
                                            <span class="badge bg-success">Active</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">Inactive</span>
                                        }
                                    </td>
                                    <td class="text-end">
                                        <a asp-action="Details" asp-route-id="@company.Id" class="btn btn-sm btn-outline-secondary"><i class="bi bi-eye"></i></a>
                                        <a asp-action="Edit" asp-route-id="@company.Id" class="btn btn-sm btn-outline-primary"><i class="bi bi-pencil"></i></a>
                                        <a asp-action="Delete" asp-route-id="@company.Id" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</section>
